# URL base da API REST do backend (FastAPI)
# Em desenvolvimento local com Docker: https://localhost:8000
# Nota: o certificado SSL é autoassinado em dev — acesse a URL uma vez no
# navegador para aceitar antes de usar o frontend.
VITE_API_URL=https://localhost:8000

# URL da API de Ciência de Dados (fire-control-data-science-main)
# Usado apenas pela integração em src/features/data-science/ — não faz parte do projeto principal.
# VITE_DS_API_URL=http://localhost:8001
