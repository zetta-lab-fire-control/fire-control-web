# URL base da API REST do backend (FastAPI)
# Usando proxy Vite em desenvolvimento local (recomendado)
VITE_API_URL=/api

# Alvo do proxy Vite → FastAPI via Nginx (certificado auto-assinado em dev)
VITE_PROXY_TARGET=https://127.0.0.1:8000

# URL da API de Ciência de Dados (fire-control-data-science-main)
# Necessário para a página /analise funcionar. Suba o serviço DS antes de rodar o frontend.
VITE_DS_API_URL=http://localhost:8001
